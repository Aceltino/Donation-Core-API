# Common application settings
PORT=3000
REDIS_URL=redis://localhost:6379

# Donation Core / Stripe settings
DATABASE_URL=postgresql://username:password@localhost:5432/database_name?schema=public
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Worker Hub / AWS Lambda settings
AWS_REGION=us-east-1
LAMBDA_FUNCTION_NAME=your_lambda_function_name

# API Gateway settings
DONATION_CORE_URL=http://localhost:3000
DONATION_SUCCESS_URL=http://localhost:3000/success
DONATION_CANCEL_URL=http://localhost:3000/cancel

# New Relic settings
NEW_RELIC_LICENSE_KEY=your_new_relic_license_key_here
NEW_RELIC_APP_NAME=donation-core-api
NEW_RELIC_LOGGING_LEVEL=info
NEW_RELIC_DISTRIBUTED_TRACING_ENABLED=true
